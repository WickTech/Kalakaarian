{
  "framework": "node",
  "buildCommand": "cd server && npm install && npm run build",
  "installCommand": "cd server && npm install",
  "outputDirectory": "server/dist",
  "builds": [
    {
      "src": "server/dist/app.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/server/dist/app.js"
    }
  ]
}